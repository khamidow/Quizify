<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0BB"
    tools:context=".ResultActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="57dp"
        android:background="#F4F0BB"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/home_btn"
            android:layout_width="33dp"
            android:layout_height="33dp"
            android:layout_marginLeft="13dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="1.7dp"
            android:src="@drawable/home"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="Result"
            android:textColor="#462B20"
            android:textSize="27sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/category_icon"
        android:layout_width="37dp"
        android:layout_height="37dp"
        android:layout_margin="19dp"
        android:src="@drawable/math_icon"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />

    <TextView
        android:id="@+id/tv_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="17dp"
        android:text="Mathematics"
        android:textColor="#85C18F"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/category_icon"
        app:layout_constraintLeft_toRightOf="@id/category_icon"
        app:layout_constraintTop_toTopOf="@id/category_icon" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="17dp"
        android:fontFamily="@font/baloo_bahaijaan2"
        android:text="Amazing"
        android:textColor="#462B20"
        android:textSize="39sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/category_icon" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/point_container"
        android:layout_width="111dp"
        android:layout_height="51dp"
        android:layout_marginTop="41dp"
        android:background="@drawable/points_bcg"
        android:elevation="5dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_status">

        <ImageView
            android:id="@+id/img_coin"
            android:layout_width="33dp"
            android:layout_height="33dp"
            android:layout_marginLeft="9dp"
            android:padding="1dp"
            android:src="@drawable/coin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/points_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="123"
            android:textColor="#F4F0BB"
            android:textSize="21.5sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/img_coin"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/correct_frame"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        android:layout_marginHorizontal="19dp"
        android:layout_marginTop="19dp"
        android:background="@drawable/variant_correct_bcg"
        android:clipToOutline="true"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/point_container">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="13dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="Correct"
            android:textColor="#F4F0BB"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/correct_count_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginRight="13dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="7"
            android:textColor="#F4F0BB"
            android:textSize="21.5sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/wrong_frame"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        android:layout_marginHorizontal="19dp"
        android:layout_marginTop="19dp"
        android:background="@drawable/variant_wrong_bcg"
        android:clipToOutline="true"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/correct_frame">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="13dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="Wrong"
            android:textColor="#F4F0BB"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wrong_count_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginRight="13dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="3"
            android:textColor="#F4F0BB"
            android:textSize="21.5sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/skip_frame"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        android:layout_marginHorizontal="19dp"
        android:layout_marginTop="19dp"
        android:background="@drawable/variant_bcg"
        android:clipToOutline="true"
        android:elevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/wrong_frame">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="13dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="Skip"
            android:textColor="#462B20"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/skip_count_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginRight="13dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:paddingTop="5dp"
            android:text="5"
            android:textColor="#462B20"
            android:textSize="21.5sp"
            android:textStyle="bold" />
    </FrameLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/view_answers_btn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="19dp"
        android:background="@drawable/bottom_btns_bcg"
        android:clipToOutline="true"
        android:elevation="5dp"
        android:fontFamily="@font/baloo_bahaijaan2"
        android:text="View answers"
        android:textAllCaps="false"
        android:textColor="#462B20"
        android:textSize="19sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>