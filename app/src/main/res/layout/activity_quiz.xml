<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0BB"
    tools:context=".QuizActivity">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="57dp"
        android:background="#F4F0BB"
        android:elevation="5dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/back_btn"
            android:layout_width="33dp"
            android:layout_height="33dp"
            android:layout_marginLeft="13dp"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="5dp"
            android:src="@drawable/back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="15dp"
            android:progressDrawable="@drawable/progress_shape"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0.6"
            app:layout_constraintLeft_toRightOf="@id/back_btn"
            app:layout_constraintRight_toLeftOf="@id/out_of_tv"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.47"
            tools:progress="59" />

        <TextView
            android:id="@+id/out_of_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_marginRight="17dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:text="1/10"
            android:textColor="#462B20"
            android:textSize="21sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/category_icon"
        android:layout_width="37dp"
        android:layout_height="37dp"
        android:layout_margin="19dp"
        android:src="@drawable/math_icon"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />

    <TextView
        android:id="@+id/tv_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="17dp"
        android:text="Mathematics"
        android:textColor="#85C18F"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/category_icon"
        app:layout_constraintLeft_toRightOf="@id/category_icon"
        app:layout_constraintTop_toTopOf="@id/category_icon" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/question_container1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/category_icon">

        <TextView
            android:id="@+id/question_tv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="19dp"
            android:layout_marginTop="19dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:gravity="center"
            android:lineHeight="37dp"
            android:minLines="2"
            android:text="What is the square root of 144?"
            android:textColor="#462B20"
            android:textSize="25sp"
            android:textStyle="bold"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Space
            android:id="@+id/space_img"
            android:layout_width="match_parent"
            android:layout_height="211dp"
            android:layout_marginTop="19dp"
            app:layout_constraintTop_toBottomOf="@id/question_tv" />

        <LinearLayout
            android:id="@+id/line_variant_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/space_img">

            <TextView
                android:id="@+id/variant1_tv"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginVertical="19dp"
                android:layout_marginLeft="19dp"
                android:layout_marginRight="9dp"
                android:layout_weight="1"
                android:background="@drawable/variant_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="11"
                android:textColor="#462B20"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/variant2_tv"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginVertical="19dp"
                android:layout_marginLeft="9dp"
                android:layout_marginRight="19dp"
                android:layout_weight="1"
                android:background="@drawable/variant_correct_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="10"
                android:textColor="#F4F0BB"
                android:textSize="19sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/line_variant_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/line_variant_1">

            <TextView
                android:id="@+id/variant3_tv"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginLeft="19dp"
                android:layout_marginTop="1dp"
                android:layout_marginRight="9dp"
                android:layout_marginBottom="19dp"
                android:layout_weight="1"
                android:background="@drawable/variant_selected_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="13"
                android:textColor="#F4F0BB"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/variant4_tv"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginLeft="9dp"
                android:layout_marginTop="1dp"
                android:layout_marginRight="19dp"
                android:layout_marginBottom="19dp"
                android:layout_weight="1"
                android:background="@drawable/variant_wrong_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="12"
                android:textColor="#F4F0BB"
                android:textSize="19sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/question_container2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/category_icon">

        <TextView
            android:id="@+id/question_tv2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="19dp"
            android:layout_marginTop="19dp"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:gravity="center"
            android:lineHeight="37dp"
            android:minLines="2"
            android:text="What is the square root of 144?"
            android:textColor="#462B20"
            android:textSize="25sp"
            android:textStyle="bold"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/space_img2"
            android:layout_width="match_parent"
            android:layout_height="211dp"
            android:layout_marginHorizontal="19dp"
            android:layout_marginTop="19dp"
            android:background="@drawable/img_shaper"
            android:clipToOutline="true"
            android:elevation="5dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            app:layout_constraintTop_toBottomOf="@id/question_tv2" />

        <LinearLayout
            android:id="@+id/line_variant_12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/space_img2">

            <TextView
                android:id="@+id/variant1_tv2"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginVertical="19dp"
                android:layout_marginLeft="19dp"
                android:layout_marginRight="9dp"
                android:layout_weight="1"
                android:background="@drawable/variant_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="11"
                android:textColor="#462B20"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/variant2_tv2"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginVertical="19dp"
                android:layout_marginLeft="9dp"
                android:layout_marginRight="19dp"
                android:layout_weight="1"
                android:background="@drawable/variant_correct_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="10"
                android:textColor="#F4F0BB"
                android:textSize="19sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/line_variant_22"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/line_variant_12">

            <TextView
                android:id="@+id/variant3_tv2"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginLeft="19dp"
                android:layout_marginTop="1dp"
                android:layout_marginRight="9dp"
                android:layout_marginBottom="19dp"
                android:layout_weight="1"
                android:background="@drawable/variant_selected_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="13"
                android:textColor="#F4F0BB"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/variant4_tv2"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginLeft="9dp"
                android:layout_marginTop="1dp"
                android:layout_marginRight="19dp"
                android:layout_marginBottom="19dp"
                android:layout_weight="1"
                android:background="@drawable/variant_wrong_bcg"
                android:clipToOutline="true"
                android:elevation="5dp"
                android:foreground="?android:selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="12"
                android:textColor="#F4F0BB"
                android:textSize="19sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/skipped_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="19dp"
        android:fontFamily="@font/baloo_bahaijaan2"
        android:text="This question was skipped!"
        android:textColor="#DA2C38"
        android:textSize="19sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_container" />

    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/prev_btn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginLeft="19dp"
            android:layout_marginTop="19dp"
            android:layout_marginBottom="19dp"
            android:layout_weight="1"
            android:background="@drawable/bottom_btns_bcg"
            android:clickable="true"
            android:elevation="5dp"
            android:focusable="true"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:foreground="?android:selectableItemBackgroundBorderless"
            android:gravity="center"
            android:text="Previous"
            android:textColor="#462B20"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/next_btn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="19dp"
            android:layout_weight="1"
            android:background="@drawable/bottom_btns_bcg"
            android:clickable="true"
            android:elevation="5dp"
            android:focusable="true"
            android:fontFamily="@font/baloo_bahaijaan2"
            android:foreground="?android:selectableItemBackgroundBorderless"
            android:gravity="center"
            android:text="Next"
            android:textColor="#462B20"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>