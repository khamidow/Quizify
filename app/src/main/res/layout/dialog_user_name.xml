<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@drawable/variant_bcg"
    android:clipToOutline="true"
    android:layout_height="match_parent">

    <EditText
        android:id="@+id/name_ed"
        android:layout_marginHorizontal="19dp"
        android:hint="Name"
        android:background="@drawable/bottom_btns_bcg"
        android:layout_width="match_parent"
        android:paddingLeft="19dp"
        app:layout_constraintTop_toTopOf="parent"
        android:textColorHint="#462B20"
        android:elevation="5dp"
        android:layout_marginTop="19dp"
        android:fontFamily="@font/baloo_bahaijaan2"
        android:textSize="21dp"
        app:layout_constraintBottom_toTopOf="@id/ok_btn"
        android:paddingTop="5dp"
        android:textStyle="bold"
        android:layout_height="55dp"/>
    <androidx.appcompat.widget.AppCompatButton
        app:layout_constraintTop_toBottomOf="@id/name_ed"
        android:id="@+id/ok_btn"
        android:layout_width="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="19dp"
        android:textAllCaps="false"
        android:fontFamily="@font/baloo_bahaijaan2"
        android:textSize="21sp"
        android:textColor="#F4F0BB"
        android:paddingTop="5dp"
        android:text="Ok"
        android:textStyle="bold"
        android:elevation="5dp"
        android:background="@drawable/variant_selected_bcg"
        android:layout_height="55dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>